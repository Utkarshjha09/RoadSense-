# Keep EAS upload lean.
# Do NOT ignore android/ because this project relies on committed native config
# that already builds locally. Ignoring it forces cloud prebuild and can produce
# incompatible autolinked native projects.
ios/
node_modules/
**/node_modules/
.gradle-local/
.gradle-user-home/
**/.gradle-user-home/

# Local caches / temp
.expo/
**/.expo/
.gradle/
**/.gradle/
build/
**/build/
dist/
web-build/
coverage/

# Native/build artifacts
*.apk
*.aab
*.apks
*.keystore
*.hprof
android/**/*.cxx/
android/**/build/
android/.gradle/

# Logs and local diagnostics
*.log
eas-log-*.txt
latest-eas-log-*.txt
build-view*.json

# IDE / OS noise
.idea/
**/.idea/
.vscode/
**/.vscode/
.DS_Store
Thumbs.db
