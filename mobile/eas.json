{
  "cli": {
    "version": ">= 16.32.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "https://YOUR_PROJECT_REF.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "YOUR_SUPABASE_ANON_KEY",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "YOUR_GOOGLE_MAPS_API_KEY",
        "EXPO_PUBLIC_OTP_SERVICE_URL": "https://YOUR_OTP_SERVICE_URL",
        "EXPO_PUBLIC_CLOUD_API_URL": "https://YOUR_RENDER_CLOUD_API_URL",
        "EXPO_PUBLIC_API_BASE_URL": "https://YOUR_RENDER_CLOUD_API_URL",
        "EXPO_PUBLIC_API_SECRET": "YOUR_API_SECRET"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "https://YOUR_PROJECT_REF.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "YOUR_SUPABASE_ANON_KEY",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "YOUR_GOOGLE_MAPS_API_KEY",
        "EXPO_PUBLIC_OTP_SERVICE_URL": "https://YOUR_OTP_SERVICE_URL",
        "EXPO_PUBLIC_CLOUD_API_URL": "https://YOUR_RENDER_CLOUD_API_URL",
        "EXPO_PUBLIC_API_BASE_URL": "https://YOUR_RENDER_CLOUD_API_URL",
        "EXPO_PUBLIC_API_SECRET": "YOUR_API_SECRET"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_SUPABASE_URL": "https://YOUR_PROJECT_REF.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "YOUR_SUPABASE_ANON_KEY",
        "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY": "YOUR_GOOGLE_MAPS_API_KEY",
        "EXPO_PUBLIC_CLOUD_API_URL": "https://YOUR_RENDER_CLOUD_API_URL",
        "EXPO_PUBLIC_API_BASE_URL": "https://YOUR_RENDER_CLOUD_API_URL",
        "EXPO_PUBLIC_API_SECRET": "YOUR_API_SECRET"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
