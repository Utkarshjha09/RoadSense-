{
  "expo": {
    "name": "RoadSense",
    "slug": "roadsense",
    "version": "1.0.1",
    "newArchEnabled": false,
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.roadsense.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "RoadSense needs your location to detect and map road anomalies.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "RoadSense needs your location to detect and map road anomalies.",
        "NSMotionUsageDescription": "RoadSense uses motion sensors to detect potholes and speed bumps."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.roadsense.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "ACTIVITY_RECOGNITION",
        "VIBRATE",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "WAKE_LOCK",
        "FOREGROUND_SERVICE",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "blockedPermissions": [],
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-build-properties",
        {
          "android": {
            "ndkVersion": "29.0.14206865"
          }
        }
      ],
      "react-native-fast-tflite",
      "./plugins/withAndroidCleartextTraffic",
      [
        "react-native-maps",
        {
          "androidGoogleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow RoadSense to use your location to detect potholes and road anomalies.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Allow RoadSense to access motion sensors for pothole detection."
        }
      ],
      "expo-asset"
    ],
    "scheme": "roadsense",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "164e5d16-0ab4-40e9-99ca-6bc2b91c3616"
      }
    },
    "owner": "utkarshjha07"
  }
}
